# Адрес HTTP-сервера
ADDR=:8081

# Postgres (миграции применяются автоматически при старте)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/streaks?sslmode=disable

# Токен бота — нужен для валидации Telegram initData (продакшен)
BOT_TOKEN=

# Только для локальной разработки: пропускает валидацию initData,
# все запросы выполняются от имени DEV_USER_ID
DEV_AUTH_BYPASS=true
DEV_USER_ID=1

# Telegram ID администраторов через запятую (админ-панель в Settings)
ADMIN_IDS=180564250
